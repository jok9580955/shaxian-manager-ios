default_platform(:ios)

APP_IDENTIFIER = "com.liulei.shaxian.kitchenmanager"
DEFAULT_ASC_API_KEY_ID = "JD5G4LG5XN"
DEFAULT_ASC_API_ISSUER_ID = "f68594d0-23a9-480d-8f1d-6c84b40bf664"
DEFAULT_ASC_API_KEYFILEPATH = "/Users/ll/Desktop/AuthKey_JD5G4LG5XN.p8"

def asc_api_key_from_env
  key_id = ENV.fetch("APP_STORE_CONNECT_API_KEY_ID", DEFAULT_ASC_API_KEY_ID)
  issuer_id = ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID", DEFAULT_ASC_API_ISSUER_ID)
  key_filepath = File.expand_path(ENV.fetch("APP_STORE_CONNECT_API_KEY_KEYFILEPATH", DEFAULT_ASC_API_KEYFILEPATH))
  unless [key_id, issuer_id, key_filepath].all? { |value| value.to_s.strip.length.positive? } && File.exist?(key_filepath)
    UI.user_error!("Missing App Store Connect API key config. Set APP_STORE_CONNECT_API_KEY_ID, APP_STORE_CONNECT_API_KEY_ISSUER_ID, APP_STORE_CONNECT_API_KEY_KEYFILEPATH or place #{DEFAULT_ASC_API_KEYFILEPATH}.")
  end

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_filepath: key_filepath,
    duration: 1200,
    in_house: false
  )
end

def app_review_information_from_env
  required_keys = %w[
    APP_REVIEW_FIRST_NAME
    APP_REVIEW_LAST_NAME
    APP_REVIEW_PHONE
    APP_REVIEW_EMAIL
  ]
  return nil unless required_keys.all? { |key| ENV[key].to_s.strip.length.positive? }

  {
    first_name: ENV.fetch("APP_REVIEW_FIRST_NAME"),
    last_name: ENV.fetch("APP_REVIEW_LAST_NAME"),
    phone_number: ENV.fetch("APP_REVIEW_PHONE"),
    email_address: ENV.fetch("APP_REVIEW_EMAIL"),
    notes: ENV.fetch("APP_REVIEW_NOTES", "This app does not require login. No demo account is required.")
  }
end

platform :ios do
  desc "Validate local ASO files before upload"
  lane :status do
    sh("bash scripts/aso_status.sh")
  end

  desc "Upload App Store metadata only"
  lane :upmeta do
    api_key = asc_api_key_from_env
    options = {
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      skip_screenshots: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      force: true
    }
    review_information = app_review_information_from_env
    options[:app_review_information] = review_information if review_information
    deliver(options)
  end

  desc "Upload App Store screenshots only"
  lane :uppic do
    api_key = asc_api_key_from_env
    deliver(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      skip_metadata: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      force: true
    )
  end

  desc "Regenerate privacy/support pages and inject public URLs into metadata"
  lane :upgit do
    UI.user_error!("Set PUBLIC_BASE_URL before running upgit") if ENV["PUBLIC_BASE_URL"].to_s.strip.empty?
    sh("bash scripts/generate_privacy_support.sh")
  end
end
